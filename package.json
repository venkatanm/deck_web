{
  "name": "deck-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx server/index.ts",
    "dev:ws": "y-websocket-server",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "dev:multiplayer": "concurrently \"npm run dev\" \"npm run dev:server\" \"npm run dev:ws\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@y/websocket-server": "^0.1.5",
    "express": "^4.21.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.576.0",
    "pptxgenjs": "^3.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.5.2",
    "sharp": "^0.34.5",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29",
    "zod": "^3.23.8",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
